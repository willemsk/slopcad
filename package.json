    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5.6.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "@biomejs/biome@1.9.4": true
